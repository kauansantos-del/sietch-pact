{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npx prisma generate",
  "outputDirectory": "public",
  "framework": null,
  "alias": ["sietch-pact-api.vercel.app"],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 10
    }
  }
}
